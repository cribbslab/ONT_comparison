library(ggvenn)
library(dplyr)
library(edgeR)
library(tidyr)
library(forcats)
library(ggpubr)
library(ggplot2)
library(knitr)
library(patchwork)
library(UpSetR)
# Resolve namespace conflicts
select <- dplyr::select
# Nature publication theme
nature_theme <- theme_classic() +
theme(
plot.title = element_text(size = 12, face = "bold", hjust = 0.5),
plot.subtitle = element_text(size = 10, hjust = 0.5),
axis.title = element_text(size = 10, face = "bold"),
axis.text = element_text(size = 9, color = "black"),
legend.title = element_text(size = 10, face = "bold"),
legend.text = element_text(size = 9),
panel.background = element_blank(),
plot.background = element_blank(),
panel.grid = element_blank(),
axis.line = element_line(color = "black", size = 0.5),
axis.ticks = element_line(color = "black", size = 0.5),
legend.background = element_blank(),
legend.key = element_blank(),
legend.position = "right",
plot.margin = margin(10, 10, 10, 10)
)
# Nature color palette (colorblind friendly)
nature_colors <- c("#E69F00", "#56B4E9", "#009E73", "#F0E442", "#0072B2", "#D55E00", "#CC79A7", "#000000")
# Import matrices
cdna_counts <- read.table("cdna2_SKMM2_counts_gene.txt", sep="\t", header=TRUE)
drna_counts <- read.table("drnasub_SKMM2_counts_gene.txt", sep="\t", header=TRUE)
# Only keep genes with at least 1 count in at least 1 sample
cdna_filt <- cdna_counts[rowSums(cdna_counts[2:7])>0,]
drna_filt <- drna_counts[rowSums(drna_counts[2:7])>0,]
# Convert raw counts to CPM
cdna_cpm <- as.data.frame(cpm(cdna_filt[2:7], log=FALSE))
cdna_cpm$GENEID <- cdna_filt$GENEID
drna_cpm <- as.data.frame(cpm(drna_filt[2:7], log=FALSE))
drna_cpm$GENEID <- drna_filt$GENEID
# Define confidence levels based on detection patterns
# Low = detected in <3 samples
# Medium = detected 3-6 samples, average <1 CPM
# High = detected in 3-6 samples, average >1CPM
cdna_cpm <- cdna_cpm %>%
mutate(mean = rowMeans(cdna_cpm[1:6]),
detect = rowSums(cdna_cpm[1:6]>0),
conf = case_when(detect < 3 ~ "Low",
detect == 6 ~ "High",
.default = "Medium"))
drna_cpm <- drna_cpm %>%
mutate(mean = rowMeans(drna_cpm[1:6]),
detect = rowSums(drna_cpm[1:6]>0),
conf = case_when(detect < 3 ~ "Low",
detect == 6 ~ "High",
.default = "Medium"))
# Create summary for stacked bar plot
stacked <- data.frame(cdna = table(cdna_cpm$conf), drna = table(drna_cpm$conf))[,-3]
stacked_m <- pivot_longer(stacked, cols = 2:3)
colnames(stacked_m) <- c("conf", "Protocol", "Number of Genes")
stacked_m <- stacked_m %>%
mutate(Protocol = as.factor(case_when(Protocol == "cdna.Freq" ~ "PCR-cDNA",
.default = "Direct RNA")))
# Figure 1: Gene Detection by Confidence Level
fig1 <- stacked_m %>%
mutate(Confidence = fct_relevel(conf, "High", "Medium", "Low")) %>%
ggplot(aes(x = Protocol, y = `Number of Genes`, fill = Confidence)) +
geom_bar(position = "stack", stat = "identity", width = 0.7, color = "black", size = 0.3) +
scale_fill_manual(values = c("#0072B2", "#56B4E9", "#E69F00")) +
labs(title = "Gene Detection by Confidence Level",
x = "Sequencing Protocol",
y = "Number of Genes") +
nature_theme
print(fig1)
# Create gene sets for analysis
gene_sets <- list(
cDNA_High = cdna_cpm$GENEID[cdna_cpm$conf == "High"],
cDNA_Medium = cdna_cpm$GENEID[cdna_cpm$conf == "Medium"],
cDNA_Low = cdna_cpm$GENEID[cdna_cpm$conf == "Low"],
dRNA_High = drna_cpm$GENEID[drna_cpm$conf == "High"],
dRNA_Medium = drna_cpm$GENEID[drna_cpm$conf == "Medium"],
dRNA_Low = drna_cpm$GENEID[drna_cpm$conf == "Low"]
)
# Function to create Venn diagrams
create_nature_venn <- function(conf_level) {
cdna_genes <- gene_sets[[paste0("cDNA_", conf_level)]]
drna_genes <- gene_sets[[paste0("dRNA_", conf_level)]]
gene_list <- list(`PCR-cDNA` = cdna_genes, `Direct RNA` = drna_genes)
ggvenn(gene_list,
fill_color = c("#0072B2", "#D55E00"),
fill_alpha = 0.7,
stroke_color = "black",
stroke_size = 0.5,
text_size = 3.5,
text_color = "black",
show_percentage = FALSE,
auto_scale = FALSE,
set_name_size = 3.5) +
labs(title = paste(conf_level, "confidence")) +
theme_void() +
theme(plot.title = element_text(size = 10, face = "bold", hjust = 0.5),
plot.margin = margin(5, 5, 5, 5))
}
# Figure 2: Faceted Venn Diagrams
fig2 <- create_nature_venn("High") + create_nature_venn("Medium") + create_nature_venn("Low") +
plot_layout(ncol = 3) +
plot_annotation(
title = "Gene Detection Overlap by Confidence Level",
theme = theme(plot.title = element_text(size = 12, face = "bold", hjust = 0.5))
)
print(fig2)
# Calculate overlaps for each confidence level
calculate_overlap <- function(set1, set2) {
length(intersect(set1, set2))
}
# Create overlap data
confidence_levels <- c("High", "Medium", "Low")
overlap_data <- data.frame()
for (conf in confidence_levels) {
cdna_genes <- gene_sets[[paste0("cDNA_", conf)]]
drna_genes <- gene_sets[[paste0("dRNA_", conf)]]
overlap <- calculate_overlap(cdna_genes, drna_genes)
cdna_only <- length(cdna_genes) - overlap
drna_only <- length(drna_genes) - overlap
temp_data <- data.frame(
Confidence = conf,
PCR_cDNA_only = cdna_only,
Overlap = overlap,
Direct_RNA_only = drna_only
)
overlap_data <- rbind(overlap_data, temp_data)
}
# Reshape for plotting
overlap_long <- overlap_data %>%
pivot_longer(cols = c("PCR_cDNA_only", "Overlap", "Direct_RNA_only"),
names_to = "Category", values_to = "Count") %>%
mutate(Category = factor(Category, levels = c("PCR_cDNA_only", "Overlap", "Direct_RNA_only")),
Confidence = factor(Confidence, levels = c("High", "Medium", "Low")))
# Figure 3: Quantitative Overlap Analysis
fig3 <- ggplot(overlap_long, aes(x = Confidence, y = Count, fill = Category)) +
geom_bar(stat = "identity", position = "stack", width = 0.7, color = "black", size = 0.3) +
scale_fill_manual(values = c("#0072B2", "#009E73", "#D55E00"),
labels = c("PCR-cDNA only", "Overlap", "Direct RNA only"),
name = "Detection Pattern") +
labs(title = "Gene Detection Patterns by Confidence Level",
x = "Confidence Level",
y = "Number of Genes") +
nature_theme +
geom_text(data = overlap_long %>% filter(Count > 50),
aes(label = Count),
position = position_stack(vjust = 0.5),
color = "white",
fontface = "bold",
size = 3)
print(fig3)
# Create UpSet data
all_genes <- unique(c(cdna_cpm$GENEID, drna_cpm$GENEID))
upset_data <- data.frame(GENEID = all_genes, stringsAsFactors = FALSE)
upset_data$PCR_cDNA_High <- upset_data$GENEID %in% gene_sets$cDNA_High
upset_data$PCR_cDNA_Medium <- upset_data$GENEID %in% gene_sets$cDNA_Medium
upset_data$PCR_cDNA_Low <- upset_data$GENEID %in% gene_sets$cDNA_Low
upset_data$Direct_RNA_High <- upset_data$GENEID %in% gene_sets$dRNA_High
upset_data$Direct_RNA_Medium <- upset_data$GENEID %in% gene_sets$dRNA_Medium
upset_data$Direct_RNA_Low <- upset_data$GENEID %in% gene_sets$dRNA_Low
# Convert to numeric
upset_data[,2:7] <- lapply(upset_data[,2:7], as.numeric)
# Figure 4: UpSet Plot
par(mar = c(5, 4, 4, 2) + 0.1)
upset(upset_data,
sets = c("PCR_cDNA_High", "PCR_cDNA_Medium", "PCR_cDNA_Low",
"Direct_RNA_High", "Direct_RNA_Medium", "Direct_RNA_Low"),
sets.bar.color = c("#0072B2", "#56B4E9", "#E69F00",
"#D55E00", "#CC79A7", "#F0E442"),
main.bar.color = "black",
matrix.color = "black",
order.by = "freq",
empty.intersections = "on",
text.scale = c(1.2, 1.0, 1.2, 1.0, 1.2, 1.0),
mainbar.y.label = "Intersection Size",
sets.x.label = "Set Size",
mb.ratio = c(0.7, 0.3))
mtext("Comprehensive Gene Detection Intersection Analysis",
side = 3, line = 1, cex = 1.2, font = 2)
knitr::opts_chunk$set(echo = TRUE, warning = FALSE, message = FALSE,
fig.width = 8, fig.height = 6, dpi = 300)
