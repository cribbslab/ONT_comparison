cdna_only <- length(cdna_genes) - overlap
drna_only <- length(drna_genes) - overlap
temp_data <- data.frame(
Confidence = conf,
PCR_cDNA_only = cdna_only,
Overlap = overlap,
Direct_RNA_only = drna_only
)
overlap_data <- rbind(overlap_data, temp_data)
}
# Reshape for plotting
overlap_long <- overlap_data %>%
pivot_longer(cols = c("PCR_cDNA_only", "Overlap", "Direct_RNA_only"),
names_to = "Category", values_to = "Count") %>%
mutate(Category = factor(Category, levels = c("PCR_cDNA_only", "Overlap", "Direct_RNA_only")),
Confidence = factor(Confidence, levels = c("High", "Medium", "Low")))
# Figure 3: Quantitative Overlap Analysis
fig3 <- ggplot(overlap_long, aes(x = Confidence, y = Count, fill = Category)) +
geom_bar(stat = "identity", position = "stack", width = 0.7, color = "black", size = 0.3) +
scale_fill_manual(values = c("#0072B2", "#009E73", "#D55E00"),
labels = c("PCR-cDNA only", "Overlap", "Direct RNA only"),
name = "Detection Pattern") +
labs(title = "Gene Detection Patterns by Confidence Level",
x = "Confidence Level",
y = "Number of Genes") +
nature_theme +
geom_text(data = overlap_long %>% filter(Count > 50),
aes(label = Count),
position = position_stack(vjust = 0.5),
color = "white",
fontface = "bold",
size = 3)
print(fig3)
# Create UpSet data
all_genes <- unique(c(cdna_cpm$GENEID, drna_cpm$GENEID))
upset_data <- data.frame(GENEID = all_genes, stringsAsFactors = FALSE)
upset_data$PCR_cDNA_High <- upset_data$GENEID %in% gene_sets$cDNA_High
upset_data$PCR_cDNA_Medium <- upset_data$GENEID %in% gene_sets$cDNA_Medium
upset_data$PCR_cDNA_Low <- upset_data$GENEID %in% gene_sets$cDNA_Low
upset_data$Direct_RNA_High <- upset_data$GENEID %in% gene_sets$dRNA_High
upset_data$Direct_RNA_Medium <- upset_data$GENEID %in% gene_sets$dRNA_Medium
upset_data$Direct_RNA_Low <- upset_data$GENEID %in% gene_sets$dRNA_Low
# Convert to numeric
upset_data[,2:7] <- lapply(upset_data[,2:7], as.numeric)
# Figure 4: UpSet Plot
# Simple approach without manual title - let UpSetR handle the plotting
upset(upset_data,
sets = c("PCR_cDNA_High", "PCR_cDNA_Medium", "PCR_cDNA_Low",
"Direct_RNA_High", "Direct_RNA_Medium", "Direct_RNA_Low"),
sets.bar.color = c("#0072B2", "#56B4E9", "#E69F00",
"#D55E00", "#CC79A7", "#F0E442"),
main.bar.color = "black",
matrix.color = "black",
order.by = "freq",
empty.intersections = "on",
text.scale = c(1.2, 1.0, 1.2, 1.0, 1.2, 1.0),
mainbar.y.label = "Intersection Size",
sets.x.label = "Set Size",
mb.ratio = c(0.7, 0.3))
# Calculate Jaccard index
jaccard_index <- function(set1, set2) {
intersection <- length(intersect(set1, set2))
union_size <- length(union(set1, set2))
return(intersection / union_size)
}
# Create comprehensive summary
summary_data <- data.frame()
for (conf in c("High", "Medium", "Low", "All")) {
if (conf == "All") {
cdna_genes <- cdna_cpm$GENEID
drna_genes <- drna_cpm$GENEID
} else {
cdna_genes <- gene_sets[[paste0("cDNA_", conf)]]
drna_genes <- gene_sets[[paste0("dRNA_", conf)]]
}
overlap <- length(intersect(cdna_genes, drna_genes))
jaccard <- jaccard_index(cdna_genes, drna_genes)
temp_data <- data.frame(
Confidence = conf,
cDNA_Total = length(cdna_genes),
dRNA_Total = length(drna_genes),
Overlap = overlap,
cDNA_Only = length(cdna_genes) - overlap,
dRNA_Only = length(drna_genes) - overlap,
Jaccard_Index = round(jaccard, 3),
Overlap_Percentage = round((overlap / length(union(cdna_genes, drna_genes))) * 100, 1)
)
summary_data <- rbind(summary_data, temp_data)
}
# Figure 5: Jaccard Index Visualization
fig5 <- ggplot(summary_data[1:3,], aes(x = factor(Confidence, levels = c("High", "Medium", "Low")),
y = Jaccard_Index, fill = Confidence)) +
geom_bar(stat = "identity", width = 0.7, color = "black", size = 0.3) +
scale_fill_manual(values = c("#0072B2", "#56B4E9", "#E69F00")) +
labs(title = "Protocol Similarity by Confidence Level",
x = "Confidence Level",
y = "Jaccard Index",
subtitle = "Jaccard index measures similarity between PCR-cDNA and Direct RNA detection") +
nature_theme +
theme(legend.position = "none",
plot.subtitle = element_text(size = 9, hjust = 0.5)) +
geom_text(aes(label = sprintf("%.3f", Jaccard_Index)),
vjust = -0.5,
fontface = "bold",
size = 3.5) +
scale_y_continuous(breaks = seq(0, 1, 0.2), limits = c(0, 1))
print(fig5)
# Create publication-ready table
summary_table_display <- summary_data %>%
mutate(
`PCR-cDNA Total` = format(cDNA_Total, big.mark = ","),
`Direct RNA Total` = format(dRNA_Total, big.mark = ","),
`Overlap` = format(Overlap, big.mark = ","),
`PCR-cDNA Only` = format(cDNA_Only, big.mark = ","),
`Direct RNA Only` = format(dRNA_Only, big.mark = ","),
`Jaccard Index` = sprintf("%.3f", Jaccard_Index),
`Overlap (%)` = paste0(Overlap_Percentage, "%")
) %>%
dplyr::select(Confidence, `PCR-cDNA Total`, `Direct RNA Total`, Overlap,
`PCR-cDNA Only`, `Direct RNA Only`, `Jaccard Index`, `Overlap (%)`)
kable(summary_table_display,
caption = "**Table 1. Gene detection overlap summary by confidence level.** Numbers represent unique genes detected in each category. Jaccard index measures similarity between detection methods (0 = no overlap, 1 = perfect overlap).",
align = c("l", rep("r", 7)))
library(DESeq2)
library(DEXSeq)
library(pheatmap)
library(ggplot2)
library(dplyr)
library(reshape2)
library(vsn)
library(ggpubr)
library(tidyr)
library(data.table)
library(venn)
library(gplots)
library(summarytools)
library(ggvenn)
library(rstatix)
#Read output from RSeQC, take mean and convert to %
gbcov=read.csv("genebodycov.csv", header=TRUE)
gbcov_m=pivot_longer(gbcov, cols=2:5)
gbcov_m$subset=ifelse(grepl("all",gbcov_m$name),'All','>1000bp')
gbcov_m$protocol=ifelse(grepl("cdna", gbcov_m$name), "cDNA", "dRNA")
ggplot(gbcov_m, aes(x=Percentile, y=value, colour=protocol, linetype=subset))+geom_line()+
ylab("Coverage")+
xlab("Gene Body Percentile (5'-> 3')")+
scale_colour_manual(values=c("turquoise3", "navy"))
