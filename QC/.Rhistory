# T-tests for median length
ctrl_length_test <- t_test(np_ctrl, Median.read.length ~ Protocol)
il6_length_test <- t_test(np_il6, Median.read.length ~ Protocol)
# T-tests for median quality
ctrl_quality_test <- t_test(np_ctrl, Median.read.quality ~ Protocol)
