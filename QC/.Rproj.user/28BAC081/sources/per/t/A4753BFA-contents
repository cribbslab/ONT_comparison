```{r similarity_analysis, fig.width=8, fig.height=6}
# Calculate Jaccard index
jaccard_index <- function(set1, set2) {
  intersection <- length(intersect(set1, set2))
  union_size <- length(union(set1, set2))
  return(intersection / union_size)
}

# Create comprehensive summary
summary_data <- data.frame()

for (conf in c("High", "Medium", "Low", "All")) {
  if (conf == "All") {
    cdna_genes <- cdna_cpm$GENEID
    drna_genes <- drna_cpm$GENEID
  } else {
    cdna_genes <- gene_sets[[paste0("cDNA_", conf)]]
    drna_genes <- gene_sets[[paste0("dRNA_", conf)]]
  }
  
  overlap <- length(intersect(cdna_genes, drna_genes))
  jaccard <- jaccard_index(cdna_genes, drna_genes)
  
  temp_data <- data.frame(
    Confidence = conf,
    cDNA_Total = length(cdna_genes),
    dRNA_Total = length(drna_genes),
    Overlap = overlap,
    cDNA_Only = length(cdna_genes) - overlap,
    dRNA_Only = length(drna_genes) - overlap,
    Jaccard_Index = round(jaccard, 3),
    Overlap_Percentage = round((overlap / length(union(cdna_genes, drna_genes))) * 100, 1)
  )
  
  summary_data <- rbind(summary_data, temp_data)
}

# Figure 5: Jaccard Index Visualization
fig5 <- ggplot(summary_data[1:3,], aes(x = factor(Confidence, levels = c("High", "Medium", "Low")), 
                                       y = Jaccard_Index, fill = Confidence)) +
  geom_bar(stat = "identity", width = 0.7, color = "black", size = 0.3) +
  scale_fill_manual(values = c("#0072B2", "#56B4E9", "#E69F00")) +
  labs(title = "Protocol Similarity by Confidence Level",
       x = "Confidence Level",
       y = "Jaccard Index",
       subtitle = "Jaccard index measures similarity between PCR-cDNA and Direct RNA detection") +
  nature_theme +
  theme(legend.position = "none",
        plot.subtitle = element_text(size = 9, hjust = 0.5)) +
  geom_text(aes(label = sprintf("%.3f", Jaccard_Index)), 
            vjust = -0.5, 
            fontface = "bold", 
            size = 3.5) +
  scale_y_continuous(breaks = seq(0, 1, 0.2), limits = c(0, 1))

print(fig5)
```

