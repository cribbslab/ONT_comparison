```{r import data}

#Import tx counts
cts=read.delim("drnasub_SKMM2_counts_transcript.txt", sep="\t")
cts=cts[rowSums(cts[3:8])>0,]
dim(cts)

#Read sample info
allinfo=read.csv("sampleinfo.csv", header=TRUE)[7:12,]
all(colnames(cts[3:8])==allinfo$sample)

#Generate txdb
txdb=loadDb("gencode.v46.annotation.sqlite")
k = keys(txdb, keytype = "GENEID")
txdf = AnnotationDbi::select(txdb, k, "TXNAME", "GENEID")

#Add HGNC symbols to counts
tx_info=read.csv("tx_v46_info.csv", header=TRUE)
annot=left_join(cts, tx_info, by="TXNAME")

rm(txdb)
```

