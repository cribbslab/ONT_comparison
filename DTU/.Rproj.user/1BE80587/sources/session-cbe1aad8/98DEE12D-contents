#Selected example - sig in both protocols
plotDTUcomp(sig_comb_m,"RPL22L1")
```

```{r rpl22l1 tx structure}
library(ggtranscript)
library(RColorBrewer)

#read in df with tx info
tx_info=read.csv("genes_interest_dtu.csv", header=TRUE)


#RPL22L1
rpl_info=tx_info[tx_info$gene_name=="RPL22L1",]
rpl_info=rpl_info[rpl_info$transcript_name %in% comb$featureID,]


rpl_exons <- rpl_info %>% dplyr::filter( type== "exon")

rpl_plot=rpl_exons%>%
    ggplot(aes(
        xstart = start,
        xend = end,
        y = transcript_name
    )) +
    geom_range(aes(fill = transcript_name))+
    scale_fill_viridis(discrete=TRUE)+
    geom_intron(
        data = to_intron(rpl_exons, "transcript_name"),
        aes(strand = strand))+
          theme_bw()+
          theme(
      legend.text = element_text(size=14),
      axis.text = element_text(size=18), 
      axis.title.x=element_text(size=18),
      axis.title.y=element_text(size=18),
      legend.position="bottom")+
  ylab("Transcript Name")
rpl_plot
```

