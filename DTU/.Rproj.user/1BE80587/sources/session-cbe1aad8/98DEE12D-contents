```{r import DTU results}

#Import Count Matrices
cdna_count=read.csv("DTU Results/cdna_txnorm.csv", header=TRUE)
drna_count=read.csv("DTU Results/drna_txnorm.csv", header=TRUE)

#Import significant genes/transcripts 
cdna_stat=read.csv("DTU Results/cdna_dexDTU.csv", header=TRUE)
drna_stat=read.csv("DTU Results/drna_dexDTU.csv", header=TRUE)

#Read in sample info 
sampleinfo=read.csv("sampleinfo.csv")

```


```{r subset matrices}
#Subset count matrices to significant genes
cdna_sig=cdna_count[,c(1:4,12)]
drna_sig=drna_count[,c(1:4,12)]

#Calculate percentage of each transcript per gene
cdna_sig= cdna_sig %>% group_by(HGNC) %>% mutate(Control = Control * 100/sum(Control), IL6=IL6*100/sum(IL6))
drna_sig= drna_sig %>% group_by(HGNC) %>% mutate(Control = Control* 100/sum(Control), IL6=IL6*100/sum(IL6))

```

```{r venns}
dtu_comp=list('PCR-cDNA'=cdna_stat$txID[cdna_stat$transcript<0.05], dRNA=drna_stat$txID[drna_stat$transcript<0.05])
dtu_gene=list('PCR-cDNA'=cdna_stat$geneID[cdna_stat$gene<0.05], dRNA=drna_stat$geneID[drna_stat$gene<0.05])

#Overlap transcripts
library(ggvenn)
ggvenn(dtu_comp, 
       show_percentage=FALSE, 
       fill_color=c("turquoise3", "navy"), 
       auto_scale=TRUE)

overlap=venn(dtu_comp, 
             show.plot=FALSE,
             intersections=TRUE)
intersections=attr(overlap, "intersections")


#Overlap genes
overlap_gene=venn(dtu_gene, 
             show.plot=FALSE,
             intersections=TRUE)
intersections_gene=attr(overlap_gene, "intersections")


```


```{r plot, significant in dRNA only}
#Combined df for dRNA and cDNA
comb=bind_rows(cdna_sig, drna_sig, .id="library")
comb$protocol=ifelse(comb$library==1, "PCR-cDNA", "directRNA")

#Sig in dRNA only- plot all
drna_comb=comb[comb$groupID %in% intersections_gene$dRNA,-1]
drna_comb_m=pivot_longer(drna_comb, cols=3:4)

for(i in unique(drna_comb_m$HGNC)){
  plot1=plotDTUcomp(drna_comb_m, i)
  print(plot1)
}
#Selected example- sig in dRNA only
plotDTUcomp(drna_comb_m, "RNF220")
```

```{r plot significant in cDNA only}
#Sig in cDNA only - plot all
cdna_comb=comb[comb$groupID %in% intersections_gene$`PCR-cDNA`, -1]
cdna_comb_m=pivot_longer(cdna_comb, cols=3:4)

for(i in unique(cdna_comb_m$HGNC)){
  plot1=plotDTUcomp(cdna_comb_m, i)
  print(plot1)
}

#Selected example, sig in cDNA only
plotDTUcomp(cdna_comb_m, "GRB2")
```

```{r plot significant in both}
#sig in both - plot all
sig_comb=comb[comb$groupID %in% intersections_gene$`PCR-cDNA:dRNA`, -1]
sig_comb_m=pivot_longer(sig_comb, cols=3:4)

for(i in unique(sig_comb_m$HGNC)){
  plot1=plotDTUcomp(sig_comb_m, i)
