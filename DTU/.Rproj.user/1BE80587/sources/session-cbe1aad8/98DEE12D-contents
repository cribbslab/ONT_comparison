```{r tx exp raw}

cdna_rawcount=read.csv("cdna2_SKMM2_counts_transcript.txt", header=TRUE, sep="\t")
drna_rawcount=read.csv("drnasub_SKMM2_counts_transcript.txt", header=TRUE, sep="\t")

#Convert raw counts to cpm
cdna_cpm=cpm(cdna_rawcount[,3:8], normalized.lib.sizes=TRUE)
drna_cpm=cpm(drna_rawcount[,3:8], normalized.lib.sizes=TRUE)

#Append gene and tx names back
cdna_cpm=data.frame(cdna_rawcount[,1:2], cdna_cpm)
drna_cpm=data.frame(drna_rawcount[,1:2], drna_cpm)

#List ensembl IDs for genes of interest
ensemblgenes=unique(comb$groupID[comb$HGNC %in% genelist])

#Subset dfs to tx of interest
cdna_cpm=cdna_cpm[cdna_cpm$TXNAME %in% comb$featureID & cdna_cpm$GENEID %in% ensemblgenes,]
drna_cpm=drna_cpm[drna_cpm$GENEID %in% ensemblgenes & drna_cpm$TXNAME %in% comb$featureID,]

#Average for Ctrl and IL6
cdna_cpmb=cdna_cpm %>% mutate(Control= rowMeans(dplyr::select(.,contains("ctrl"), n=3)), IL6= rowMeans(dplyr::select(.,contains("IL6"),n=3)))

drna_cpmb=drna_cpm %>% mutate(Control = rowMeans(dplyr::select(.,contains("ctrl"))), IL6= rowMeans(dplyr::select(.,contains("IL6"))))

#Subset
cdna_cpmb=cdna_cpmb[, c(1:2, 9:10)]
drna_cpmb=drna_cpmb[, c(1:2, 9:10 )]

#Convert to log2
cdna_cpmb[, 3:4]=log2(cdna_cpmb[,3:4]+1)
drna_cpmb[,3:4]=log2(drna_cpmb[,3:4]+1)

#Prep df to plot
comb_cpm=bind_rows(cdna_cpmb, drna_cpmb, .id="protocol")
comb_cpm$protocol=if_else(comb_cpm$protocol==1, "PCR-cDNA", "direct RNA")
comb_cpm=left_join(comb_cpm, tx_info[, 6:7], by=join_by("TXNAME"=="transcript_name"), multiple="any")
comb_cpm_m=pivot_longer(comb_cpm, cols=4:5)

#RPL22L1
ggplot(comb_cpm_m[comb_cpm_m$gene_name=="RPL22L1",], aes(x=name, y=value, fill=TXNAME, group=name)) + geom_col() + scale_fill_viridis(discrete=TRUE) + facet_wrap(~protocol)+
  xlab("Condition") + ylab(" log2 Normalised Count per Million (CPM)")+
  theme(
      legend.text = element_text(size =14),
      axis.text = element_text(size = 18), 
      axis.title.x=element_text(size=18),
      axis.title.y=element_text(size=18),
      legend.position="bottom")
#GRB2
ggplot(comb_cpm_m[comb_cpm_m$gene_name=="GRB2",], aes(x=name, y=value, fill=TXNAME, group=name)) + geom_col() + scale_fill_viridis(discrete=TRUE) + facet_wrap(~protocol)+
  xlab("Condition") + ylab("log2 Normalised Count per Million (CPM)") +theme(
      legend.text = element_text(size =14),
      axis.text = element_text(size = 18), 
      axis.title.x=element_text(size=18),
      axis.title.y=element_text(size=18),
      legend.position="bottom")
#RNF220
ggplot(comb_cpm_m[comb_cpm_m$gene_name=="RNF220",], aes(x=name, y=value, fill=TXNAME, group=name)) + geom_col() + scale_fill_viridis(discrete=TRUE) + facet_wrap(~protocol)+
  xlab("Condition") + ylab("Transcript Count per Million (CPM)")+theme(
