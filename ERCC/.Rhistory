width = 4.5, height = 4, units = "in", dpi = 300)
gb_cov=read.csv("genebody_cov.csv", header=TRUE)[, 1:5]
gb_cov_m=pivot_longer(gb_cov, cols=c(2:5))
protocol=strsplit2(gb_cov_m$name, "_")
colnames(protocol)=c("Protocol", "Transcripts")
gb_cov_all=data.frame(gb_cov_m, protocol)
# Publication-quality gene body coverage plot
coverage_plot <- ggplot(gb_cov_all, aes(x=Percentile, y=value,
color=Protocol, linetype=Transcripts)) +
geom_line(linewidth = 1) +
scale_x_continuous(breaks = seq(0, 100, 20), expand = c(0.02, 0)) +
scale_y_continuous(expand = c(0.02, 0)) +
scale_color_manual(values = c("cDNA" = "#17BECF", "dRNA" = "#1F77B4"),
labels = c("PCR-cDNA", "Direct RNA")) +
scale_linetype_manual(values = c("dashed", "solid"),
labels = c("All", "Selected")) +
labs(x = "Transcript Percentile (5' → 3')",
y = "Normalised Coverage Depth") +
theme_classic() +
theme(
axis.text = element_text(size = 8, color = "black"),
axis.title = element_text(size = 9, color = "black"),
legend.text = element_text(size = 8, color = "black"),
legend.title = element_text(size = 8, color = "black"),
legend.position = "top",
legend.box = "horizontal",
axis.line = element_line(color = "black", linewidth = 0.5),
axis.ticks = element_line(color = "black", linewidth = 0.5),
axis.ticks.length = unit(2, "pt"),
panel.background = element_rect(fill = "white", color = NA),
plot.background = element_rect(fill = "white", color = NA),
legend.key = element_blank()
) +
guides(color = guide_legend(title = "Protocol", order = 1),
linetype = guide_legend(title = "Transcripts", order = 2))
ggsave("gene_body_coverage.pdf", coverage_plot,
width = 4.5, height = 4, units = "in", dpi = 300)
read.depth=read.table("FC_readdepth.txt", header=TRUE, skip=1)
magic_fun <- function(x){
if_else(x>0, 1, 0)
}
read.depth.detect=data.frame(lapply(read.depth[,3:8], magic_fun))
read.depth.detect=data.frame(read.depth$conc, read.depth.detect)
colnames(read.depth.detect)=c("Transcript_Concentration", "1M", "250k", "2M", "500k", "5M", "GC")
rdd_m=pivot_longer(read.depth.detect, cols=2:6)
# Reorder levels for logical display
rdd_m$name <- factor(rdd_m$name, levels = c("250k", "500k", "1M", "2M", "5M"))
# Publication-quality sequencing depth sensitivity plot
depth_sensitivity_plot <- ggplot(rdd_m, aes(x=Transcript_Concentration, y=value,
color=name)) +
geom_point(size = 1, alpha = 0.7, position = position_jitter(height = 0.02)) +
scale_x_log10(breaks = c(0.01, 0.1, 1, 10, 100, 1000),
labels = c("0.01", "0.1", "1", "10", "100", "1000")) +
scale_y_continuous(limits = c(-0.05, 1.05),
breaks = seq(0, 1, 0.2),
expand = c(0.02, 0)) +
stat_smooth(method = "glm", se = FALSE, linewidth = 1,
method.args = list(family = binomial)) +
scale_color_viridis_d(name = "Read Depth",
labels = c("250K", "500K", "1M", "2M", "5M")) +
labs(x = expression("log"[10]*" Transcript Concentration (aM/μL)"),
y = "Probability of Detection") +
theme_classic() +
theme(
axis.text = element_text(size = 8, color = "black"),
axis.title = element_text(size = 9, color = "black"),
legend.text = element_text(size = 8, color = "black"),
legend.title = element_text(size = 8, color = "black"),
legend.position = "right",
axis.line = element_line(color = "black", linewidth = 0.5),
axis.ticks = element_line(color = "black", linewidth = 0.5),
axis.ticks.length = unit(2, "pt"),
panel.background = element_rect(fill = "white", color = NA),
plot.background = element_rect(fill = "white", color = NA),
legend.key = element_blank()
)
ggsave("sequencing_depth_sensitivity.pdf", depth_sensitivity_plot,
width = 5, height = 3.5, units = "in", dpi = 300)
# Summary message
cat("All ERCC analysis plots saved as publication-quality PDFs:\n")
cat("- read_length_distribution.pdf\n")
cat("- transcript_detection_probability.pdf\n")
cat("- concentration_vs_cpm_faceted.pdf\n")
cat("- concentration_vs_cpm_combined.pdf\n")
cat("- gene_body_coverage.pdf\n")
cat("- sequencing_depth_sensitivity.pdf\n")
