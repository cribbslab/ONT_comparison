library(dplyr)
library(ggpubr)
library(ggpattern)
library(tidyverse)
library(ggplot2)
library(pheatmap)
library(DESeq2)
library(kableExtra)
library(vsn)
library(ggfortify)
library(AnnotationDbi)
library (org.Hs.eg.db)
library(PCAtools)
library(reshape2)
library(RColorBrewer)
library(fgsea)
library(GOSemSim)
library(enrichplot)
library(clusterProfiler)
library(ggvenn)
library(gplots)
library(purrr)
library(biomaRt)
library(GSEABase)
library(GSVA)
source("customfunc.R")
#Annotate protocol and bind
dge_comb=left_join(cdna_dge[,c(2,7)], drna_dge[,c(2,7)],by="hgnc")
colnames(dge_comb)=c("PCR-cDNA", "hgnc", "DirectRNA")
dge_comb_m=pivot_longer(dge_comb, cols=c(1,3))
scatter_plot <- ggplot(dge_comb, aes(x=`PCR-cDNA`, y=DirectRNA))+
geom_point(size = 0.8, alpha = 0.6, color = "black") +
scale_y_continuous(limits = c(-2.5, 5),
breaks = seq(-2, 5, 1),
expand = c(0.02, 0)) +
scale_x_continuous(limits = c(-2.5, 5),
breaks = seq(-2, 5, 1),
expand = c(0.02, 0)) +
geom_smooth(method = "lm", color = "red", linewidth = 0.8, se = FALSE) +
labs(x = "PCR-cDNA log₂FC",
y = "Direct RNA log₂FC") +
stat_regline_equation(label.x = -2.2, label.y = 4.5,
size = 2.5, color = "black") +
stat_cor(label.x = -2.2, label.y = 4.0,
size = 2.5, color = "black") +
theme_classic() +
theme(
axis.text = element_text(size = 8, color = "black"),
axis.title = element_text(size = 9, color = "black"),
axis.line = element_line(color = "black", linewidth = 0.5),
axis.ticks = element_line(color = "black", linewidth = 0.5),
axis.ticks.length = unit(2, "pt"),
plot.margin = margin(10, 10, 10, 10),
panel.background = element_rect(fill = "white", color = NA),
plot.background = element_rect(fill = "white", color = NA)
) +
coord_fixed(ratio = 1)
ggsave("dge_correlation_scatterplot.pdf", scatter_plot,
width = 3.5, height = 3.5, units = "in", dpi = 300)
knitr::opts_chunk$set(echo = TRUE)
library(dplyr)
library(ggplot2)
library(pheatmap)
library(DESeq2)
library(kableExtra)
library(vsn)
library(ggfortify)
library(PCAtools)
library(AnnotationDbi)
library (org.Hs.eg.db)
library(PCAtools)
library(reshape2)
library(RColorBrewer)
library(fgsea)
library(GOSemSim)
library(enrichplot)
library(clusterProfiler)
library(ggvenn)
library(gplots)
library(purrr)
library(ggrepel)  # For gene label positioning
source("customfunc.R")
#Count matrix
readcounts=read.table("drnasub_SKMM2_counts_gene.txt", row.names=1, header=T, sep="\t")
readcounts$ensembl=rownames(readcounts)
#Annotate HGNC symbols
gene_info=read.csv("tx_v46_info.csv", header=TRUE)[,c(2:3)]
readcounts_an=left_join(readcounts, gene_info, by=join_by(ensembl==GENENAME), multiple="any")
rownames(readcounts_an)=readcounts_an$ensembl
#Sample Information
sampleinfo=read.table("sampleinfo.csv", header=T, row.names=1, sep=",")[7:12,]
sampleinfo$Condition=as.factor(sampleinfo$Condition)
#Filter out 'IG' genes
ig=grep('^IGH|^IGK|^IGL|^HLA', readcounts_an$HGNC)
readcounts_an=readcounts_an[-ig,]
#Make DESeq Dataset & Filter No Counts
readcounts_an[,1:6]=sapply(readcounts_an[1:6], as.integer)
dds=DESeqDataSetFromMatrix(countData=readcounts_an[,1:6],
colData=sampleinfo,
design=~Condition)
hgnc=readcounts_an$HGNC
mcols(dds)= DataFrame(mcols(dds), hgnc)
mcols(dds)
#DESeq Object
dds <- estimateSizeFactors(dds)
dds=dds[rowSums(counts(dds))>=1,]
#DESeq + VSD Normalisation
dds=DESeq(dds)
vsd=vst(dds, blind=FALSE)
vsd_mat=as.matrix(assay(vsd))
meanSdPlot(vsd_mat, ranks=FALSE)
#Extract results for each contrast into df
my.contrasts=resultsNames(dds)[2]
result_list <- list()
for (i in my.contrasts)
{ res <- results(dds, name=i, alpha=0.05)
result_list[i] <- res
}
df_list=lapply(result_list, as.data.frame)
df_list=lapply(df_list, mutate,hgnc=dds@rowRanges@elementMetadata$hgnc)
lapply(result_list, head)
lapply(result_list, DESeq2::summary)
#Annotate significance with more refined categories
df_list=lapply(df_list, mutate,
sig=case_when(
padj < 0.05 & log2FoldChange > 1 ~ "Upregulated",
padj < 0.05 & log2FoldChange < -1 ~ "Downregulated",
padj < 0.05 & abs(log2FoldChange) <= 1 ~ "Significant",
.default = "Not significant"
))
# Publication-ready volcano plot
volcano_data <- df_list$Condition_IL6_vs_Control
# Define colors for publication
volcano.colours <- c(
"Upregulated" = "#E31A1C",      # Red
"Downregulated" = "#1F78B4",    # Blue
"Significant" = "#33A02C",      # Green
"Not significant" = "#636363"   # Gray
)
# Create publication-quality volcano plot
volcano_plot <- ggplot(volcano_data, aes(x = log2FoldChange, y = -log10(padj), color = sig)) +
geom_point(size = 0.8, alpha = 0.7) +
scale_color_manual(values = volcano.colours,
name = "",
breaks = c("Upregulated", "Downregulated", "Significant", "Not significant")) +
# Add significance thresholds
geom_hline(yintercept = -log10(0.05), color = "black", linetype = "dashed", linewidth = 0.5) +
geom_vline(xintercept = c(-1, 1), color = "black", linetype = "dashed", linewidth = 0.5) +
# Set axis limits and breaks
scale_y_continuous(
limits = c(0, 25),
breaks = seq(0, 25, 5),
expand = c(0.02, 0)
) +
scale_x_continuous(
limits = c(-10, 10),
breaks = seq(-10, 10, 2),
expand = c(0.02, 0)
) +
# Labels
labs(
x = expression("log"[2]*" fold change"),
y = expression("-log"[10]*" adjusted P-value")
) +
# Publication theme
theme_classic() +
theme(
axis.text = element_text(size = 8, color = "black"),
axis.title = element_text(size = 9, color = "black"),
legend.text = element_text(size = 8, color = "black"),
legend.position = "top",
legend.justification = "center",
legend.margin = margin(0, 0, 10, 0),
axis.line = element_line(color = "black", linewidth = 0.5),
axis.ticks = element_line(color = "black", linewidth = 0.5),
axis.ticks.length = unit(2, "pt"),
plot.margin = margin(10, 10, 10, 10),
panel.background = element_rect(fill = "white", color = NA),
plot.background = element_rect(fill = "white", color = NA),
legend.key = element_blank()
) +
# Add count annotations
annotate("text", x = 8, y = 23,
label = paste0("Up: ", sum(volcano_data$sig == "Upregulated", na.rm = TRUE)),
size = 2.5, color = "#E31A1C") +
annotate("text", x = -8, y = 23,
label = paste0("Down: ", sum(volcano_data$sig == "Downregulated", na.rm = TRUE)),
size = 2.5, color = "#1F78B4")
# Save as publication-ready PDF
ggsave("volcano_plot_publication.pdf", volcano_plot,
width = 4, height = 4.5, units = "in", dpi = 300)
# Optional: Add gene labels for top significant genes
# Identify top genes to label (most significant up and down)
top_genes <- volcano_data %>%
filter(sig %in% c("Upregulated", "Downregulated")) %>%
arrange(padj) %>%
head(10)
# Volcano plot with gene labels
volcano_plot_labeled <- volcano_plot +
geom_text_repel(
data = top_genes,
aes(label = hgnc),
size = 2.5,
color = "black",
max.overlaps = 10,
box.padding = 0.3,
point.padding = 0.3,
segment.size = 0.3,
segment.color = "black",
show.legend = FALSE
)
# Save labeled version
ggsave("volcano_plot_with_labels.pdf", volcano_plot_labeled,
width = 4.5, height = 4.5, units = "in", dpi = 300)
#Export results
write.csv(df_list$Condition_IL6_vs_Control,"DGE_drnasub.csv")
knitr::opts_chunk$set(echo = TRUE)
library(biomaRt)
library(Biobase)
library(GSVA)
library(GSEABase)
library(dplyr)
library(ggplot2)
library(pheatmap)
library(DESeq2)
library(kableExtra)
library(vsn)
library(ggfortify)
library(PCAtools)
library(AnnotationDbi)
library (org.Hs.eg.db)
library(PCAtools)
library(reshape2)
library(RColorBrewer)
library(fgsea)
library(GOSemSim)
library(enrichplot)
library(clusterProfiler)
library(ggvenn)
library(gplots)
library(purrr)
library(ggrepel)  # For gene label positioning
source("customfunc.R")
#Count matrix
readcounts=read.table("cdna2_SKMM2_counts_gene.txt", header=T, sep="\t")[,1:7]
#Annotate HGNC symbols
gene_info=read.csv("tx_v46_info.csv", header=TRUE)[,c(2:3)]
readcounts_an=left_join(readcounts, gene_info, by=join_by(GENEID==GENENAME), multiple="any")
rownames(readcounts_an)=readcounts_an$ensembl
#Sample Information
sampleinfo=read.table("sampleinfo.csv", header=T, row.names=1, sep=",")[1:6,]
sampleinfo$Condition=as.factor(sampleinfo$Condition)
#Filter out 'IG' genes
ig=grep('^IGH|^IGK|^IGL|^HLA', readcounts_an$HGNC)
readcounts_an=readcounts_an[-ig,]
#Make DESeq Dataset & Filter No Counts
readcounts_an[,2:7]=sapply(readcounts_an[,2:7], as.integer)
rownames(readcounts_an)=readcounts_an$GENEID
dds=DESeqDataSetFromMatrix(countData=readcounts_an[,2:7],
colData=sampleinfo,
design=~Condition)
hgnc=readcounts_an$HGNC
mcols(dds)= DataFrame(mcols(dds), hgnc)
mcols(dds)
#DESeq Object
dds <- estimateSizeFactors(dds)
dds=dds[rowSums(counts(dds))>=1,]
#DESeq + VSD Normalisation
dds=DESeq(dds)
vsd=vst(dds, blind=FALSE)
vsd_mat=as.matrix(assay(vsd))
meanSdPlot(vsd_mat, ranks=FALSE)
pca_res=prcomp(t(vsd_mat), scale.=TRUE)
# Publication-quality PCA plot
pca_plot <- autoplot(pca_res, data=sampleinfo, colour='Condition', shape='Experiment', size=3) +
scale_color_manual(values=c("Control"="navy", "IL6"="red")) +
theme_classic() +
theme(
axis.text = element_text(size = 8, color = "black"),
axis.title = element_text(size = 9, color = "black"),
legend.text = element_text(size = 8, color = "black"),
legend.title = element_text(size = 8, color = "black"),
legend.position = "top",
axis.line = element_line(color = "black", linewidth = 0.5),
axis.ticks = element_line(color = "black", linewidth = 0.5),
panel.background = element_rect(fill = "white", color = NA),
plot.background = element_rect(fill = "white", color = NA)
)
ggsave("pca_plot_cdna_publication.pdf", pca_plot,
width = 4, height = 3.5, units = "in", dpi = 300)
#Extract results for each contrast into df
my.contrasts=resultsNames(dds)[2]
result_list <- list()
for (i in my.contrasts)
{ res <- results(dds, name=i, alpha=0.05)
result_list[i] <- res
}
df_list=lapply(result_list, as.data.frame)
df_list=lapply(df_list, mutate,hgnc=dds@rowRanges@elementMetadata$hgnc)
lapply(result_list, head)
lapply(result_list, DESeq2::summary)
#Annotate significance with refined categories
df_list=lapply(df_list, mutate,
sig=case_when(
padj < 0.05 & log2FoldChange > 1 ~ "Upregulated",
padj < 0.05 & log2FoldChange < -1 ~ "Downregulated",
padj < 0.05 & abs(log2FoldChange) <= 1 ~ "Significant",
.default = "Not significant"
))
# Publication-ready volcano plot
volcano_data <- df_list$Condition_IL6_vs_Control
# Define colors for publication
volcano.colours <- c(
"Upregulated" = "#E31A1C",      # Red
"Downregulated" = "#1F78B4",    # Blue
"Significant" = "#33A02C",      # Green
"Not significant" = "#636363"   # Gray
)
# Create publication-quality volcano plot for cDNA
cdna_volcano_plot <- ggplot(volcano_data, aes(x = log2FoldChange, y = -log10(padj), color = sig)) +
geom_point(size = 0.8, alpha = 0.7) +
scale_color_manual(values = volcano.colours,
name = "",
breaks = c("Upregulated", "Downregulated", "Significant", "Not significant")) +
# Add significance thresholds
geom_hline(yintercept = -log10(0.05), color = "black", linetype = "dashed", linewidth = 0.5) +
geom_vline(xintercept = c(-1, 1), color = "black", linetype = "dashed", linewidth = 0.5) +
# Set axis limits and breaks
scale_y_continuous(
limits = c(0, 25),
breaks = seq(0, 25, 5),
expand = c(0.02, 0)
) +
scale_x_continuous(
limits = c(-10, 10),
breaks = seq(-10, 10, 2),
expand = c(0.02, 0)
) +
# Labels
labs(
x = expression("log"[2]*" fold change"),
y = expression("-log"[10]*" adjusted P-value"),
title = "PCR-cDNA"
) +
# Publication theme
theme_classic() +
theme(
axis.text = element_text(size = 8, color = "black"),
axis.title = element_text(size = 9, color = "black"),
plot.title = element_text(size = 10, color = "black", hjust = 0.5),
legend.text = element_text(size = 8, color = "black"),
legend.position = "top",
legend.justification = "center",
legend.margin = margin(0, 0, 10, 0),
axis.line = element_line(color = "black", linewidth = 0.5),
axis.ticks = element_line(color = "black", linewidth = 0.5),
axis.ticks.length = unit(2, "pt"),
plot.margin = margin(10, 10, 10, 10),
panel.background = element_rect(fill = "white", color = NA),
plot.background = element_rect(fill = "white", color = NA),
legend.key = element_blank()
) +
# Add count annotations
annotate("text", x = 8, y = 23,
label = paste0("Up: ", sum(volcano_data$sig == "Upregulated", na.rm = TRUE)),
size = 2.5, color = "#E31A1C") +
annotate("text", x = -8, y = 23,
label = paste0("Down: ", sum(volcano_data$sig == "Downregulated", na.rm = TRUE)),
size = 2.5, color = "#1F78B4")
# Save as publication-ready PDF
ggsave("volcano_plot_cdna_publication.pdf", cdna_volcano_plot,
width = 4, height = 4.5, units = "in", dpi = 300)
# Optional: Add gene labels for top significant genes
# Identify top genes to label (most significant up and down)
top_genes_cdna <- volcano_data %>%
filter(sig %in% c("Upregulated", "Downregulated")) %>%
arrange(padj) %>%
head(10)
# Volcano plot with gene labels
cdna_volcano_plot_labeled <- cdna_volcano_plot +
geom_text_repel(
data = top_genes_cdna,
aes(label = hgnc),
size = 2.5,
color = "black",
max.overlaps = 10,
box.padding = 0.3,
point.padding = 0.3,
segment.size = 0.3,
segment.color = "black",
show.legend = FALSE
)
# Save labeled version
ggsave("volcano_plot_cdna_with_labels.pdf", cdna_volcano_plot_labeled,
width = 4.5, height = 4.5, units = "in", dpi = 300)
# Create summary statistics
cat("cDNA DGE Summary:\n")
cat("Upregulated genes (FC > 2, padj < 0.05):", sum(volcano_data$sig == "Upregulated", na.rm = TRUE), "\n")
cat("Downregulated genes (FC < -2, padj < 0.05):", sum(volcano_data$sig == "Downregulated", na.rm = TRUE), "\n")
cat("Total significant genes:", sum(volcano_data$sig %in% c("Upregulated", "Downregulated", "Significant"), na.rm = TRUE), "\n")
write.csv(df_list$Condition_IL6_vs_Control, "DGE_cdna.csv")
